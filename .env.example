# Supabase (required for auth, database, edge functions)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# RevenueCat (subscriptions) - use test key for development
EXPO_PUBLIC_REVENUECAT_API_KEY=test_cxZudULGeCAIPWriTOCiBQDcfHP

# PostHog (product analytics)
EXPO_PUBLIC_POSTHOG_API_KEY=your_posthog_api_key_here

# --- Supabase Edge Function secrets (not used by Expo; set with: supabase secrets set KEY=value) ---
# schedule-daily-games:
# ANTHROPIC_API_KEY=
# ANTHROPIC_DAILY_PUZZLE_SKILL_ID=skill_01AbCdEfGhIjKlMnOpQrStUv  # "Daily Puzzle Generator" skill id from console.anthropic.com
# ANTHROPIC_DAILY_PUZZLE_SKILL_VERSION=latest                     # optional; pin a version from List Skill Versions API
# DISABLE_CLAUDE_SKILL=1                                          # optional; force plain Claude API (ignore skill id)
